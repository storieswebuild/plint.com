---
import Base from '../layouts/Base.astro';
---
<Base title="About — Plint">
  <section class="page-hero section-dark">
    <div class="container">
      <h1>Our story</h1>
      <p class="lede">
        For over 25 years, Plint has been at the heart of media localisation, shaping the industry from the days of DVDs to today's AI-driven workflows.
      </p>
    </div>
  </section>
  <section class="container">
    <p><em>Pixel-perfect rebuild in progress.</em></p>
  </section>
</Base>

<style>
  .page-hero {
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem 0;
  }
  .lede { max-width: 60ch; line-height: 1.5; opacity: 0.8; }
</style>
