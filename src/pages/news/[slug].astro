---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('news');
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

interface Props { post: CollectionEntry<'news'>; }
const { post } = Astro.props;
const { Content } = await render(post);

function fmtDate(d: Date): string {
  return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
}
---
<Base title={`${post.data.title} — Plint`} description={post.data.excerpt} headerTone="dark">
  <article>
    <header class="post-header container">
      <div class="meta">
        <span class="cat">{post.data.category}</span>
        <span class="dot">·</span>
        <time datetime={post.data.date.toISOString()}>{fmtDate(post.data.date)}</time>
      </div>
      <h1>{post.data.title}</h1>
    </header>

    {post.data.hero && (
      <div class="hero-image container">
        <img src={post.data.hero} alt="" />
      </div>
    )}

    <div class="post-body container">
      <Content />
    </div>

    <footer class="post-footer container">
      <a class="back" href="/news/">← All news</a>
    </footer>
  </article>
</Base>

<style is:global>
  .post-body p { font-size: 1.125rem; line-height: 1.65; max-width: 70ch; margin: 0 auto 1.5em; }
  .post-body h2, .post-body h3 { max-width: 70ch; margin-left: auto; margin-right: auto; }
  .post-body h2 { font-size: 2rem; margin-top: 2.5em; margin-bottom: 0.5em; }
  .post-body h3 { font-size: 1.5rem; margin-top: 2em; margin-bottom: 0.5em; }
  .post-body img { max-width: 100%; margin: 2em auto; }
  .post-body ul { max-width: 70ch; margin: 0 auto 1.5em; padding-left: 1.5em; line-height: 1.65; }
  .post-body a { color: var(--color-accent); text-decoration: underline; }
  .post-body strong { font-weight: 700; }
  .post-body em { font-style: italic; }
</style>

<style>
  .post-header {
    padding: 8rem 0 3rem;
    text-align: center;
  }
  .meta {
    display: inline-flex;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }
  .meta .cat { color: var(--color-accent); }
  h1 {
    font-size: clamp(2rem, 4.5vw, 4rem);
    line-height: 1.05;
    max-width: 22ch;
    margin: 0 auto;
  }
  .hero-image {
    margin-bottom: 4rem;
  }
  .hero-image img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }
  .post-body {
    padding-bottom: 4rem;
  }
  .post-footer {
    padding: 2rem 0 6rem;
    text-align: center;
  }
  .back {
    display: inline-block;
    color: var(--color-accent);
    font-size: 0.95rem;
  }
</style>
