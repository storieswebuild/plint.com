---
import Base from '../layouts/Base.astro';

const solutions = [
  { name: 'Subtitling', href: '/solutions/subtitling/', desc: 'High-quality subtitles, in any language, for any audience — powered by our next-generation localisation technology.' },
  { name: 'Dubbing', href: '/solutions/dubbing/', desc: 'Studio-grade dubbing with a deep network of voice talent and audio engineers across 100+ languages.' },
  { name: 'Access Services', href: '/solutions/access-services/', desc: 'SDH, audio description, and other accessibility services that make content available to every viewer.' },
  { name: 'Technology', href: '/solutions/technology/', desc: 'A purpose-built localisation platform that reduces manual intervention while preserving natural-sounding language.' },
];
---
<Base title="Solutions — Plint">
  <section class="page-hero">
    <div class="page-hero-img">
      <img src="/images/site/solutions-spheres.png" alt="" />
    </div>
    <div class="page-hero-text container">
      <h1>Our solutions</h1>
    </div>
  </section>

  <section class="intro container">
    <p>
      At Plint, we offer a complete suite of language and media services — from subtitling and dubbing to accessibility, quality control, and beyond. Whether you&rsquo;re a global streaming platform or an independent studio, we have the expertise, technology, and people to deliver localisation at any scale.
    </p>
  </section>

  <section class="grid container">
    {solutions.map((s) => (
      <article class="card">
        <h2>{s.name}</h2>
        <p>{s.desc}</p>
      </article>
    ))}
  </section>
</Base>

<style>
  .page-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    color: var(--color-fg-on-dark);
    overflow: hidden;
    background: #000;
  }
  .page-hero-img { position: absolute; inset: 0; }
  .page-hero-img img { width: 100%; height: 100%; object-fit: cover; }
  .page-hero-text {
    position: relative;
    z-index: 1;
    padding: 0 2rem 4rem;
    width: 100%;
  }
  .page-hero h1 {
    font-size: clamp(3rem, 7vw, 7rem);
    line-height: 1;
    margin: 0;
  }
  .intro {
    padding: 6rem 0 3rem;
    max-width: 60ch;
    margin: 0 auto;
  }
  .intro p {
    font-size: clamp(1.125rem, 1.4vw, 1.4rem);
    line-height: 1.55;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 3rem;
    padding: 3rem 2rem 8rem;
  }
  .card h2 {
    font-size: clamp(1.5rem, 2.5vw, 2.25rem);
    line-height: 1.1;
    margin: 0 0 1rem;
  }
  .card p {
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.55;
  }
</style>
