---
import Base from '../layouts/Base.astro';
---
<Base title="Our solutions — Plint">
  <section class="page-hero">
    <div class="container">
      <h1>Our solutions</h1>
    </div>
  </section>
  <section class="container intro">
    <p>At Plint, we offer a complete suite of language and media services — from subtitling and dubbing to accessibility, quality control, and beyond.</p>
    <p><em>Pixel-perfect rebuild in progress.</em></p>
  </section>
</Base>

<style>
  .page-hero {
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    padding: 6rem 0 3rem;
    background: #f3f3f3;
  }
  .intro {
    padding: 4rem 0;
    max-width: 70ch;
  }
</style>
