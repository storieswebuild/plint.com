---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const latestNews = (await getCollection('news'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 1)[0];
---
<Base title="Plint — Pioneering the next era of localisation">
  <section class="hero">
    <div class="hero-img">
      <img src="/images/site/hero-sphere.png" alt="" />
    </div>
    <div class="hero-text container">
      <p class="eyebrow">Localisation evolved</p>
      <h1>Pioneering the next era of localisation</h1>
    </div>
  </section>

  <section class="intro section-dark">
    <div class="container">
      <p>
        There&rsquo;s a global appetite for local content. TV series from Hungary have found a new audience in Brazil. German documentaries are devoured in Korea. From the silver screen in Paris to the iPad in Ghana, more content than ever before travels the world.
      </p>
      <p>
        With well over 20 years of expertise in the localisation industry, we know how to master the art of localisation in this new era, and we are proud to be a trusted partner to some of the world&rsquo;s leading entertainment studios, streaming platforms, and content creators.
      </p>
    </div>
  </section>

  {latestNews && (
    <section class="latest-news container">
      <p class="eyebrow">News</p>
      <a class="news-card" href={`/news/${latestNews.data.slug}/`}>
        <div class="news-text">
          <h2>{latestNews.data.title}</h2>
          <p>Click here to read our latest press release</p>
        </div>
        {latestNews.data.hero && <img src={latestNews.data.hero} alt="" />}
      </a>
    </section>
  )}
</Base>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: flex-end;
    color: var(--color-fg-on-dark);
    overflow: hidden;
    background: #000;
  }
  .hero-img {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-text {
    position: relative;
    z-index: 1;
    padding: 0 2rem 4rem;
    width: 100%;
  }
  .eyebrow {
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
    opacity: 0.85;
  }
  .hero h1 {
    max-width: 12ch;
    font-size: clamp(3rem, 7vw, 7rem);
    line-height: 1;
    margin: 0;
  }
  .intro {
    padding: 8rem 0;
  }
  .intro .container {
    max-width: 50ch;
    margin: 0 auto;
  }
  .intro p {
    font-size: clamp(1.125rem, 1.4vw, 1.4rem);
    line-height: 1.5;
    margin-bottom: 1.5em;
  }
  .latest-news {
    padding: 6rem 0;
  }
  .latest-news .eyebrow { color: var(--color-accent); margin-bottom: 2rem; }
  .news-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    color: inherit;
  }
  .news-card:hover { text-decoration: none; }
  .news-card:hover h2 { color: var(--color-accent); }
  .news-card img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }
  .news-card h2 {
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    line-height: 1.1;
    margin: 0 0 1rem;
    transition: color 0.2s ease;
  }
  .news-card .news-text p {
    color: var(--color-muted);
    font-size: 1rem;
  }
  @media (max-width: 768px) {
    .news-card { grid-template-columns: 1fr; gap: 1.5rem; }
  }
</style>
