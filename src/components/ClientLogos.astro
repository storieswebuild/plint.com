---
const logos = [
  { src: '/images/logos/viaplay.png', alt: 'Viaplay' },
  { src: '/images/logos/paramount.png', alt: 'Paramount' },
  { src: '/images/logos/nbcu.png', alt: 'NBCUniversal' },
  { src: '/images/logos/wb.png', alt: 'Warner Bros.' },
  { src: '/images/logos/netflix.png', alt: 'Netflix' },
  { src: '/images/logos/eu.png', alt: 'EU' },
];
---
<section class="client-logos">
  <div class="track">
    {[...logos, ...logos].map((logo) => (
      <div class="logo">
        <img src={logo.src} alt={logo.alt} loading="lazy" />
      </div>
    ))}
  </div>
</section>

<style>
  .client-logos {
    background: #000;
    overflow: hidden;
    padding: 4rem 0;
  }
  .track {
    display: flex;
    align-items: center;
    gap: 6rem;
    width: max-content;
    animation: scroll 40s linear infinite;
  }
  .logo {
    flex: 0 0 auto;
    width: 180px;
    height: 110px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 1rem;
  }
  .logo img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: invert(1);
    opacity: 0.95;
  }
  @keyframes scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .track { animation: none; }
  }
</style>
