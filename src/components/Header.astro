---
import Logo from './Logo.astro';

const links = [
  { href: '/solutions/', label: 'Solutions' },
  { href: '/about/', label: 'About' },
  { href: '/news/', label: 'News' },
  { href: '/contact/', label: 'Contact' },
];
const here = Astro.url.pathname;
---
<header class="site-header">
  <a class="brand" href="/" aria-label="Plint — home">
    <Logo height={28} />
  </a>
  <nav>
    <ul>
      {links.map(({ href, label }) => (
        <li class:list={[{ active: here.startsWith(href) }]}>
          <a href={href}>{label}</a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: absolute;
    top: 0; left: 0; right: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    z-index: 10;
    /* Default to white header — most pages open with a dark hero. Pages with a
       light hero (e.g. /news/) override this via [data-header-tone="dark"]. */
    color: var(--color-fg-on-dark);
  }
  :global([data-header-tone="dark"]) .site-header {
    color: var(--color-fg);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    color: inherit;
  }
  .brand:hover { text-decoration: none; }
  nav ul {
    display: flex;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  nav a {
    font-size: 0.95rem;
    color: inherit;
    padding-bottom: 0.25rem;
  }
  nav li.active a {
    color: var(--color-accent);
    border-bottom: 1px solid var(--color-accent);
  }
</style>
